TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# === AI Productivity Coach ===
# Set ONE provider key (or both — Gemini is preferred when present).

# Option A — FREE: Google Gemini. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional. Free-tier model. Default: gemini-2.5-flash
GEMINI_MODEL=

# Option B — PAID: Anthropic Claude. Get a key at https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=
# Optional. Default: claude-sonnet-4-6 | cheapest: claude-haiku-4-5 | most capable: claude-opus-4-8
ANTHROPIC_MODEL=

# Optional. Force a provider regardless of which keys are set: "gemini" or "anthropic".
AI_PROVIDER=